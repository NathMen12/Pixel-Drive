# ===========================================
# PixelDrive - Environment Variables Template
# Copy to .env and fill in your values
# ===========================================

# App Configuration
NODE_ENV=production
PORT=7860
APP_URL=http://localhost:7860

# JWT Secrets (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))")
JWT_SECRET=your_64_char_base64_secret_here
JWT_REFRESH_SECRET=your_64_char_base64_refresh_secret_here
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Cookie Settings
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# Database (MySQL - Aiven or local)
DB_HOST=localhost
DB_PORT=3306
DB_USER=pixeldrive
DB_PASSWORD=pixeldrive
DB_NAME=pixeldrive
# For Aiven SSL: DB_CA_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
DB_CA_CERT=

# ImgBB API Key (get from https://api.imgbb.com/)
IMGBB_API_KEY=your_imgbb_api_key_here

# Rate Limiting
RATE_LIMIT_AUTH=10/15m
RATE_LIMIT_UPLOAD=50/1m
RATE_LIMIT_API=100/1m

# Sharp Concurrency (thumbnails)
SHARP_CONCURRENCY=2

# Storage
CHUNK_SIZE=26214400
# 25 MiB = 26214400 bytes