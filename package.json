{
  "name": "pixeldrive",
  "version": "1.0.0",
  "description": "Zero-Knowledge Cloud Storage with Pixel Steganography",
  "type": "module",
  "main": "src/server/index.js",
  "scripts": {
    "dev": "node --watch src/server/index.js",
    "start": "node src/server/index.js",
    "db:migrate": "node src/server/db/migrate.js",
    "db:seed": "node src/server/db/seed.js",
    "test": "node --test src/**/*.test.js",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "docker:build": "docker build -t pixeldrive .",
    "docker:run": "docker run -p 7860:7860 --env-file .env pixeldrive"
  },
  "keywords": [
    "cloud-storage",
    "zero-knowledge",
    "e2ee",
    "steganography",
    "pwa"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.7.2",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "form-data": "^4.0.0",
    "helmet": "^7.1.0",
    "jimp": "^0.22.10",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.10.0",
    "sharp": "^0.33.4",
    "socket.io": "^4.7.5",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "eslint": "^9.5.0",
    "globals": "^15.6.0",
    "prettier": "^3.3.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
